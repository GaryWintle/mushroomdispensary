---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import CTAButton from "./CTAButton.astro";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  hasGuide: boolean;
  guideUrl?: string;
}

const { title, description, image, hasGuide, guideUrl } = Astro.props;
---

<div class="product-card section--light">
  <div class="card-image">
    <Image src={image} width={600} height={400} alt={title} />
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
  </div>
  {
    hasGuide && (
      <div class="card-footer">
        <CTAButton text="Free User Guide" />
      </div>
    )
  }
</div>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface-light);
    border-radius: var(--br-03);
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }

  .card-image {
    height: 300px;
    border-bottom: var(--border-surface-color-thin);
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    flex: 1;
  }
</style>
