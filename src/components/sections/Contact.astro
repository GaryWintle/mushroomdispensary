---
import { Image } from "astro:assets";

import location1 from "@images/locations/mushdisp-location-01.webp";
import location2 from "@images/locations/mushdisp-location-02.avif";
import location3 from "@images/locations/mushdisp-location-03.jpg";

import LocationCard from "@components/ui/LocationCard.astro";

const locations = [
  {
    cityArea: "West End Vancouver",
    address: "1674 Davie St.",
    storeHours: [
      { days: "Mon-Wed", hours: "11am-7pm" },
      { days: "Thu-Sat", hours: "10am-11pm" },
      { days: "Sun", hours: "11am-6pm" },
    ],
    image: location1,
  },
  {
    cityArea: "East Vancouver",
    address: "651 East Hastings",
    storeHours: [
      { days: "Mon-Thu", hours: "10am-10pm" },
      { days: "Fri-Sat", hours: "10am-11pm" },
      { days: "Sun", hours: "11am-6pm" },
    ],
    image: location2,
  },
  {
    cityArea: "Mount Pleasant",
    address: "247 West Broadway",
    storeHours: [
      { days: "Mon-Wed", hours: "11am-7pm" },
      { days: "Thu-Sat", hours: "10am-10pm" },
      { days: "Sun", hours: "11am-6pm" },
    ],
    image: location3,
  },
];
---

<section class="section section--dark">
  <div class="container">
    <div class="contact-container">
      <div class="locations-header">
        <div class="phone-container">
          <h2>3 Locations</h2>
          <p>We have three storefronts in Vancouver, BC, Canada</p>
          <p>Phone numbers for all locations:</p>
          <p>604-343-4687</p>
        </div>
        <div class="phone-container">
          <h2>Adults Only</h2>
          <p>
            Minors cannot enter unless accompanied by a parent. Minors cannot
            make any purchases.
          </p>
        </div>
      </div>
      <div class="locations-card">
        {
          locations.map((location) => (
            <LocationCard
              cityArea={location.cityArea}
              address={location.address}
              storeHours={location.storeHours}
              image={location.image}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .contact-container {
    display: grid;
    grid-template-columns: 1fr 2fr;
    grid-template-areas: "sidebar cards";
  }
  .locations-header {
    grid-area: sidebar;
  }
  .locations-card {
    grid-area: cards;
    display: flex;
    flex-direction: column;
    gap: var(--sp-04);
  }
</style>
