---
import CarouselArrow from "@components/artwork/CarouselArrow.astro";
import MushyGuySmiley from "@components/artwork/MushGuySmiley.astro";
import ArrowTwisty from "@components/artwork/ArrowTwisty.astro";

interface Props {
  images: { src: string; alt: string; caption?: string }[];
}
const { images } = Astro.props;
---

<section
  class="embla section section--dark container"
  aria-label="Store photo gallery"
  aria-roledescription="carousel"
>
  <div class="product-heading">
    <div class="text-title-hero">
      <h2>In Vancouver?</h2>
    </div>
    <div class="text-body-display">
      <p class="text-body">
        We are Vancouver’s source for microdose and high-dose psychedelics and
        plant medicines. Come check us out!
      </p>
    </div>
    <div class="wrapper-twisty-arrow">
      <ArrowTwisty />
    </div>
  </div>
  <div class="embla__viewport">
    <div class="embla__container">
      {
        images.map((img, i) => (
          <div
            class="embla__slide"
            role="group"
            aria-roledescription="slide"
            aria-label={`${i + 1} of ${images.length}`}
          >
            <img
              src={img.src}
              alt={img.alt}
              loading={i === 0 ? "eager" : "lazy"}
              draggable="false"
            />
            {img.caption && <p class="slide__caption">{img.caption}</p>}
          </div>
        ))
      }
    </div>
  </div>
  <div class="wrapper-mushyguy-smiley">
    <MushyGuySmiley />
  </div>
  <button class="embla__btn embla__btn--prev" aria-label="Previous slide">
    <div class="arrow arrow--left"><CarouselArrow /></div>
  </button>
  <button class="embla__btn embla__btn--next" aria-label="Next slide">
    <div class="arrow arrow--right"><CarouselArrow /></div>
  </button>
  <div class="embla__dots" aria-label="Slide navigation" role="tablist"></div>
</section>

<style>
  .product-heading {
    display: flex;
    gap: var(--sp-06);
    align-items: center;
    margin-block-end: var(--sp-08);
  }
  .text-title-hero {
    flex: 1 0 none;
    color: var(--color-surface-dark-text-highlight);
    font-family: var(--font-display);
    font-size: clamp(1rem, 3.5vw, 3.5rem);
    text-transform: uppercase;
    text-box: trim-both cap alphabetic;
  }

  .text-body-display {
    flex: 1 0 25%;
    font-size: var(--text-lg);
  }

  .text-body {
    width: 90%;
  }

  .wrapper-twisty-arrow {
    position: absolute;
    top: 10px;
    right: -30px;
    transform: rotate(20deg);
    z-index: 2;
  }

  .embla {
    position: relative;
    /* overflow: hidden;  */
    border-radius: var(--br-03);
    /* margin-bottom: 120px; */
  }

  .embla__viewport {
    overflow: hidden;
    cursor: grab;
    border: var(--border-photo-dark-thin);
    border-radius: var(--br-03);
    box-shadow: var(--card-shadow-neutral-deep);
  }

  .embla__viewport.is-dragging {
    cursor: grabbing;
  }

  .embla__container {
    display: flex;
    touch-action: pan-y; /* allows vertical scroll, horizontal swipe */
  }

  .embla__slide {
    position: relative;
    flex: 0 0 100%; /* one slide at a time */
    min-width: 0;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--br-03);
    /* padding-left: var(--sp-04); */
  }

  .embla__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
    border-radius: var(--br-03);
  }

  .slide__caption {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    padding: var(--sp-03) var(--sp-06);
    border-radius: var(--br-03) var(--br-03) 0 0;
    background-color: var(--color-secondary-200);
    /* background-color: var(--color-neutral-600-90); */
    border-left: var(--border-surface-color-thick);
    border-top: var(--border-surface-color-thick);
    border-right: var(--border-surface-color-thick);
    color: var(--color-neutral-200);
    font-family: var(--font-body);
    font-size: var(--text-base);
    letter-spacing: var(--tracking-loose);
    font-variation-settings:
      "wdth" 100,
      "wght" 700;
    opacity: 0;
    transition:
      opacity 250ms ease,
      transform 250ms ease;
  }

  .embla__slide:hover .slide__caption {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
  }

  /* Position your buttons */
  .embla__btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    z-index: 2;
    padding: 0;
  }
  .embla__btn--prev,
  .embla__btn--next {
    transform: scale(1);
    transition: transform 250ms ease;
  }
  .embla__btn--prev:hover,
  .embla__btn--next:hover {
    transform: scale(1.05);
  }
  .embla__btn--prev {
    left: var(--sp-04);
    filter: var(--art-shadow-neutral-medium);
  }
  .embla__btn--next {
    right: var(--sp-04);
    filter: var(--art-shadow-neutral-medium);
  }
  .arrow--right {
    transform: rotate(180deg);
  }

  /* Dots */
  .embla__dots {
    display: flex;
    justify-content: center;
    gap: var(--sp-02);
    padding-block-start: var(--sp-06);
  }

  :global(.embla__dot) {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 3px solid var(--color-secondary-200);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 200ms ease;
    box-shadow: var(--card-shadow-neutral-shallow);
  }

  :global(.embla__dot.is-selected) {
    background: var(--color-primary-200);
  }

  .wrapper-mushyguy-smiley {
    width: 5rem;
    position: absolute;
    bottom: 140px;
    right: 0;
    z-index: 2;
    pointer-events: none;
    animation: bounce 2s ease-in-out infinite;
  }
</style>

<script>
  import EmblaCarousel from "embla-carousel";

  const viewport = document.querySelector<HTMLElement>(".embla__viewport")!;
  const embla = EmblaCarousel(viewport, {
    loop: true,
    dragFree: false,
    containScroll: "trimSnaps",
  });

  // Buttons
  document
    .querySelector(".embla__btn--prev")!
    .addEventListener("click", () => embla.scrollPrev());
  document
    .querySelector(".embla__btn--next")!
    .addEventListener("click", () => embla.scrollNext());

  // Drag cursor
  viewport.addEventListener("pointerdown", () =>
    viewport.classList.add("is-dragging"),
  );
  viewport.addEventListener("pointerup", () =>
    viewport.classList.remove("is-dragging"),
  );

  // Dots
  const dotsContainer = document.querySelector(".embla__dots")!;
  const dots = embla.scrollSnapList().map((_, i) => {
    const dot = document.createElement("button");
    dot.className = "embla__dot";
    dot.setAttribute("role", "tab");
    dot.setAttribute("aria-label", `Go to slide ${i + 1}`);
    dot.addEventListener("click", () => embla.scrollTo(i));
    dotsContainer.appendChild(dot);
    return dot;
  });

  const updateDots = () => {
    dots.forEach((dot, i) => {
      dot.classList.toggle("is-selected", i === embla.selectedScrollSnap());
    });
  };
  embla.on("select", updateDots);
  updateDots(); // set initial state

  // Reduced motion
  if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    embla.reInit({ duration: 0 });
  }

  const updateSelected = () => {
    embla.slideNodes().forEach((slide, i) => {
      slide.classList.toggle("is-active", i === embla.selectedScrollSnap());
    });
  };

  embla.on("select", updateSelected);
  updateSelected(); // set on load
</script>
