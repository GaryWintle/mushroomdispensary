---
import Smiley from "@components/artwork/Smiley.astro";
import SeenOnTV from "@components/artwork/SeenOnTV.astro";
import CanadaFlag from "@components/artwork/CanadaFlag.astro";
---

<section class="section section--light hero">
  <div class="container">
    <div class="hero-grid">
      <div class="hero-card">
        <Smiley />
        <SeenOnTV />
        <h1 class="text-title-hero">
          Dedicated to&#8200;a&#8200;safe, psychedelic supply
        </h1>
        <p class="text-body-display hero-text-body">
          We believe in the benefits of psychedelics and want to challenge
          <span class="inline-icon">
            <CanadaFlag />
          </span>
          's failed drug prohibition laws.
        </p>
      </div>
      <div class="hero-video">
        <div class="video-wrapper">
          <!-- To re-enable autoplay, add autoplay=1& before mute=1 in the src -->
          <div class="video-overlay"></div>
          <iframe
            src="https://www.youtube-nocookie.com/embed/0rFVeZ9mpe0?autoplay=1&mute=1&loop=1&playlist=0rFVeZ9mpe0&controls=0&modestbranding=1&rel=0"
            title="Hero video"
            loading="eager"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    container-type: inline-size;
    container-name: hero;
    padding-block-start: var(--sp-06);
    padding-block-end: var(--sp-05);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--sp-04);
  }

  @container hero (max-width: 48rem) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }

  .hero-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--sp-04);
    background-color: var(--color-surface-light);
    border-radius: var(--br-03);
    padding-block: var(--sp-07);
    padding-inline: var(--sp-06);
    box-shadow: var(--card-shadow-neutral-deep);
  }

  .hero-text-body {
    width: var(--measure-narrow);
  }

  .hero-video {
    border-radius: var(--br-03);
    overflow: hidden;
    box-shadow: var(--card-shadow-neutral-deep);
  }

  .video-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
  }
  .video-wrapper::after {
    content: "";
    position: absolute;
    inset: 10px;
    box-shadow: inset 0 0 0 2px oklch(from var(--color-primary-200) l c h / 0.8);
    z-index: 1;
    pointer-events: none;
    border-radius: var(--br-02);
  }
  .video-wrapper::before {
    content: "";
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 35px 5px var(--color-neutral-600-50);
    z-index: 1;
    pointer-events: none;
  }

  .video-wrapper iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    cursor: default;
  }

  .video-wrapper:hover .video-overlay {
    pointer-events: none;
  }

  .inline-icon {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
  }

  .inline-icon svg {
    width: 1em;
    height: auto;
  }
</style>
