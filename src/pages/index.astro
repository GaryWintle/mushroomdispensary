---
import Layout from "@layouts/Layout.astro";

import Hero from "@components/sections/Hero.astro";
import Testimonials from "@components/sections/Testimonials.astro";
import InTheNews from "@components/sections/InTheNews.astro";
import Products from "@components/sections/Products.astro";
import PhotoCarousel from "@components/sections/PhotoCarousel.astro";
import Contact from "@components/sections/Contact.astro";

const images = [
  {
    src: "/images/CarouselPhotos/mushdisp-dana-counter.webp",
    alt: "Store front on Main Street",
    caption: "Founder Dana Larsen working the desk",
  },
  {
    src: "/images/CarouselPhotos/mushdisp-products.webp",
    alt: "Interior mushroom display",
    caption: "A beautiful collection of just some of our products",
  },
  {
    src: "/images/CarouselPhotos/mushdisp-storefront.jpg",
    alt: "Interior mushroom display",
    caption: "Please stop by for a visit!",
  },
];
---

<Layout>
  <Hero />
  <Testimonials />
  <InTheNews />
  <Products />
  <PhotoCarousel images={images} />
  <!-- <Contact /> -->
</Layout>
