---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import CTAButton from "./CTAButton.astro";
import FreeUserGuideIcon from "./FreeUserGuideIcon.astro";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  hasGuide: boolean;
}

const {
  title = "Mushroom Dispensary",
  description = "This is just default text!",
  image,
  hasGuide = false,
} = Astro.props;
---

<div class="card-wrapper">
  <div class="product-card section--light">
    <div class="card-image">
      <Image src={image} width={600} height={400} alt={title} />
    </div>
    <div class="card-text-body">
      <h3 class="card-title">{title}</h3>
      <p class="card-description">{description}</p>
    </div>
  </div>
  {
    hasGuide && (
      <div class="user-guide">
        <FreeUserGuideIcon />
      </div>
    )
  }
</div>

<style>
  .card-wrapper {
    position: relative;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface-light);
    border-radius: var(--br-03) 3rem var(--br-03) var(--br-03);
    height: 100%;
    /* aspect-ratio: 3 / 4; */
    overflow: hidden;
    box-shadow: var(--card-shadow-neutral-medium);
    /* border: var(--border-surface-color-thick); */
  }

  .card-image {
    height: auto;
    aspect-ratio: 4 / 3;
    border-bottom: var(--border-surface-color-thick);
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-text-body {
    flex: 1;
    padding-block-start: var(--sp-06);
    padding-block-end: var(--sp-07);
    padding-inline: var(--sp-05);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    margin-block-end: var(--sp-02);
    letter-spacing: var(--tracking-loose);
    line-height: var(--leading-tight);
    /* text-transform: uppercase; */
    text-wrap: balance;
  }
  .card-description {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    /* padding-inline-end: 2px; */
    line-height: var(--leading-normal);
    letter-spacing: var(--tracking-normal);
    font-variation-settings:
      "wdth" 100,
      "wght" 600;
    text-wrap: balance;
  }

  .user-guide {
    position: absolute;
    right: -18px;
    top: 38%;
    transform: rotate(15deg);
    filter: var(--art-shadow-neutral-medium);
  }
</style>
