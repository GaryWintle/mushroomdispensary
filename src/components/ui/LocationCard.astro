---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import location1 from "@images/locations/mushdisp-location-01.webp";

// interface Props {
//   location: string;
//   address: string;
//   image: ImageMetadata;
//   hasGuide: boolean;
//   href: string;
// }

// const {
//   title = "Mushroom Dispensary",
//   description = "This is just default text!",
//   image,
//   hasGuide = false,
//   href = "/products",
// } = Astro.props;
---

<div class="location">
  <div class="location-image">
    <Image
      src={location1}
      loading="lazy"
      width={600}
      height={400}
      alt="location"
    />
  </div>
  <div class="location-text-block">
    <h3>West End Vancouver</h3>
    <h4>1674 Davie St.</h4>
  </div>
  <div>
    <p>Mon-Wed: 11am–7pm</p>
    <p>Thu-Sat: 10am–11pm</p>
    <p>Sun: 11am-6pm</p>
  </div>
</div>

<style>
  .location {
    display: flex;
  }
  .location-image {
    height: auto;
    aspect-ratio: 2 / 1;
    border-right: var(--border-surface-color-thick);
    overflow: hidden;
  }

  .location-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
