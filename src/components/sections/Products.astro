---
import CTAButton from "@components/ui/CTAButton.astro";
import ProductCard from "@components/ui/ProductCard.astro";
import ArrowTwisty from "@components/artwork/ArrowTwisty.astro";
import MushyGuyHazy from "@images/mushyguyHazy.svg?raw";

import imgMushrooms from "@images/products/mushrooms.webp";
import imgCapsules from "@images/products/mushroom-capsules.jpg";
import imgKratom from "@images/products/kratom.jpg";
import imgCocaLeaf from "@images/products/coca-leaf.avif";
import imgPeyote from "@images/products/peyote.jpg";
import imgLSD from "@images/products/lsd.webp";
import imgDMT from "@images/products/dmt.jpg";
import imgBooks from "@images/products/books.jpg";

const products = [
  {
    id: 1,
    title: "Dried Mushrooms",
    description:
      "Classic and exotic dried strains, plus chocolates and gummies.",
    image: imgMushrooms,
    hasGuide: true,
    href: "",
  },
  {
    id: 2,
    title: "Mushroom Capsules",
    description:
      "Microdose capsules in precise strengths from 12.5mg to 500mg.",
    image: imgCapsules,
    hasGuide: true,
    href: "",
  },
  {
    id: 3,
    title: "Kratom",
    description:
      "Powder and capsule form, with a range of strains for energy, focus, and relaxation.",
    image: imgKratom,
    hasGuide: true,
    href: "",
  },
  {
    id: 4,
    title: "Coca Leaf",
    description: "Whole leaf for chewing or powdered for tea, stocks vary.",
    image: imgCocaLeaf,
    hasGuide: true,
    href: "",
  },
  {
    id: 5,
    title: "Peyote",
    description: "The sacred mescaline cactus, dried or as live plants.",
    image: imgPeyote,
    hasGuide: true,
    href: "",
  },
  {
    id: 6,
    title: "LSD",
    description: "Liquid and paper tabs, available in microdose and full-dose.",
    image: imgLSD,
    hasGuide: true,
    href: "",
  },
  {
    id: 7,
    title: "DMT",
    description: "Intense 15-minute experiences via vape pen or raw powder.",
    image: imgDMT,
    hasGuide: true,
    href: "",
  },
  {
    id: 8,
    title: "Books & Art",
    description: "Books, comics and art — all priced below Amazon.",
    image: imgBooks,
    hasGuide: false,
    href: "",
  },
];
---

<div class="wrapper">
  <section class="section section--dark">
    <div class="container">
      <div class="products">
        <div class="product-heading">
          <div class="text-title-hero"><h2>Our Products</h2></div>
          <div class="text-body-display">
            <p class="text-body">
              No other shop in the world carries the same range of products that
              we do!
            </p>
          </div>
          <div class="cta">
            <div class="wrapper-twisty-arrow">
              <ArrowTwisty />
            </div>
            <div class="wrapper-mushyguy-hazy">
              <Fragment set:html={MushyGuyHazy} />
            </div>
            <div class="wrapper-cta-button">
              <CTAButton text="Full Menu!" />
            </div>
          </div>
        </div>
        <div class="product-grid">
          {
            products.map((product) => (
              <ProductCard
                title={product.title}
                description={product.description}
                image={product.image}
                hasGuide={product.hasGuide}
                href={product.href}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>
</div>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: ".products",
      start: "top 80%",
    },
  });

  tl.from(".product-heading", {
    opacity: 0,
    y: 20,
    duration: 0.5,
    ease: "power2.out",
  }).from(
    ".product-grid .card-wrapper",
    {
      opacity: 0,
      duration: 1,
      ease: "power2.out",
      stagger: 0.25,
    },
    "+=0.1",
  );
</script>

<style>
  /* .wrapper {
    background:
      url("/images/mushdisp-pattern-05percent.webp"),
      linear-gradient(
        to bottom,
        oklch(from var(--color-secondary-200) l c h / 0.8) 70%,
        oklch(from var(--color-secondary-200) l c h / 0.6) 200%
      );
    background-repeat: repeat;
    background-size: auto;
    background-attachment: fixed;
    margin-block: 100px;
  } */

  .product-heading {
    display: flex;
    gap: var(--sp-06);
    align-items: center;
    margin-block-end: var(--sp-08);
  }
  .text-title-hero {
    flex: 1 0 none;
    color: var(--color-surface-dark-text-highlight);
    font-family: var(--font-display);
    font-size: clamp(1rem, 3.5vw, 3.5rem);
    text-transform: uppercase;
    text-box: trim-both cap alphabetic;
  }

  .text-body-display {
    flex: 1 0 25%;
    font-size: var(--text-lg);
  }

  .text-body {
    width: 100%;
  }

  .cta {
    position: relative;
    flex: 1 0 none;
    display: flex;
    isolation: isolate;
  }

  .wrapper-twisty-arrow {
    position: absolute;
    top: -85px;
    left: -90px;
    transform: rotate(-30deg);
    z-index: 2;
  }
  .wrapper-cta-button {
    transform: rotate(6deg);
  }
  .wrapper-mushyguy-hazy {
    width: 8rem;
    position: absolute;
    top: -120px;
    right: -45px;
    z-index: 2;
    pointer-events: none;
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-3px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .wrapper-mushyguy-hazy {
      animation: none;
    }
  }

  /* PRODUCT CARDS */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
    align-items: stretch;
    column-gap: var(--sp-05);
    row-gap: var(--sp-06);
  }
</style>
